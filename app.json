{
  "expo": {
    "name": "Rovia",
    "slug": "rovia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/rovia-app-icon-1024.png",
    "scheme": "rovia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spectruh.StrasGuide"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/rovia-app-icon-1024.png",
        "backgroundColor": "#1A1A1A",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.spectruh.StrasGuide",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/roviaiconsplashblack.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1A1A1A",
          "dark": {
            "backgroundColor": "#1A1A1A"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Show current location on map."
        }
      ],
      "expo-localization",
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8741d07d-7901-48c2-9c99-d6f7c802eb63"
      }
    },
    "owner": "spctr_e",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/fa8462bd-597f-4ba4-8402-6ab329a7e05b"
    }
  }
}